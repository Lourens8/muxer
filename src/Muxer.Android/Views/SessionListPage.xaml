<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Muxer.Android.ViewModels"
             xmlns:svc="clr-namespace:Muxer.Android.Services"
             x:Class="Muxer.Android.Views.SessionListPage"
             Title="Muxer"
             x:DataType="vm:SessionListViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" Padding="16" RowSpacing="12">

        <!-- Status bar -->
        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="8">
            <BoxView WidthRequest="12" HeightRequest="12" CornerRadius="6"
                     VerticalOptions="Center"
                     Color="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}" />
            <Label Grid.Column="1" Text="{Binding StatusText}" FontSize="12" TextColor="Gray"
                   VerticalOptions="Center" LineBreakMode="TailTruncation" />
            <Button Grid.Column="2" Text="Refresh" Command="{Binding RefreshCommand}"
                    FontSize="11" Padding="8,2" HeightRequest="30" />
            <Button Grid.Column="3"
                    Text="{Binding IsPushEnabled, StringFormat='{0:Push: On;;Push: Off}'}"
                    Command="{Binding TogglePushCommand}"
                    BackgroundColor="{Binding IsPushEnabled, Converter={StaticResource BoolToColorConverter}}"
                    TextColor="White" FontSize="11" Padding="8,2" HeightRequest="30" />
            <Button Grid.Column="4" Text="Settings" Command="{Binding ToggleSettingsCommand}"
                    FontSize="11" Padding="8,2" HeightRequest="30" />
        </Grid>

        <!-- Settings panel (collapsible) -->
        <Border Grid.Row="1" Stroke="#444" StrokeThickness="1" Padding="12"
                StrokeShape="RoundRectangle 8" IsVisible="{Binding ShowSettings}">
            <VerticalStackLayout Spacing="10">
                <Label Text="Servers" FontSize="16" FontAttributes="Bold" />

                <Label Text="{Binding Source={x:Static svc:ServerSettings.DefaultServer},
                       StringFormat='Default: {0}'}"
                       FontSize="12" TextColor="Gray" FontFamily="monospace"
                       x:DataType="vm:SessionListViewModel" />

                <CollectionView ItemsSource="{Binding ExtraServers}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Grid ColumnDefinitions="*,Auto" Padding="0,2">
                                <Label Text="{Binding .}" FontSize="13" FontFamily="monospace"
                                       VerticalOptions="Center" />
                                <Button Grid.Column="1" Text="Remove"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SessionListViewModel}}, Path=RemoveServerCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#880000" TextColor="White"
                                        FontSize="11" Padding="10,4" HeightRequest="30" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Entry Placeholder="http://192.168.0.X:5199"
                           Text="{Binding NewServerUrl}" FontSize="13" />
                    <Button Grid.Column="1" Text="Add Server"
                            Command="{Binding AddServerCommand}"
                            BackgroundColor="#4CAF50" TextColor="White"
                            FontSize="12" Padding="12,4" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- New session -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <Entry Placeholder="Project name or pick below..."
                   Text="{Binding NewProjectName}" />
            <Button Grid.Column="1" Text="Start" Command="{Binding CreateSessionCommand}"
                    BackgroundColor="#4CAF50" TextColor="White" />
        </Grid>

        <!-- Active sessions label -->
        <Label Grid.Row="3" Text="Active Sessions" FontSize="18" FontAttributes="Bold"
               IsVisible="{Binding Sessions.Count, Converter={StaticResource IntToBoolConverter}}" />

        <!-- Session list + project list -->
        <ScrollView Grid.Row="4">
            <VerticalStackLayout Spacing="12">

                <CollectionView ItemsSource="{Binding Sessions}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:SessionViewModel">
                            <Border Stroke="#333" StrokeThickness="1" Padding="12"
                                    StrokeShape="RoundRectangle 8" Margin="0,0,0,8">
                                <VerticalStackLayout Spacing="8">

                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <BoxView WidthRequest="12" HeightRequest="12" CornerRadius="6"
                                                 Color="{Binding NeedsApproval, Converter={StaticResource ApprovalColorConverter}}" />
                                        <VerticalStackLayout Grid.Column="1" Margin="8,0,0,0">
                                            <Label Text="{Binding ProjectName}"
                                                   FontSize="16" FontAttributes="Bold" />
                                            <Label Text="{Binding ServerLabel}" FontSize="11"
                                                   TextColor="Gray" FontFamily="monospace" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2" Text="{Binding StatusText}"
                                               FontSize="12" TextColor="Gray" VerticalOptions="Center" />
                                    </Grid>

                                    <!-- Auto-approve toggle -->
                                    <HorizontalStackLayout Spacing="8">
                                        <Switch IsToggled="{Binding AutoApprove}"
                                                OnColor="#4CAF50" ThumbColor="#ccc"
                                                VerticalOptions="Center" />
                                        <Label Text="Auto-approve" FontSize="13"
                                               TextColor="{Binding AutoApprove, Converter={StaticResource BoolToColorConverter}}"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>

                                    <!-- Approval section -->
                                    <Border StrokeThickness="1" Stroke="#FF9800"
                                            StrokeShape="RoundRectangle 6"
                                            BackgroundColor="#2a2000" Padding="10"
                                            IsVisible="{Binding NeedsApproval}">
                                        <VerticalStackLayout Spacing="8">
                                            <Label Text="Permission Request" FontSize="11"
                                                   TextColor="#FF9800" FontAttributes="Bold" />
                                            <Label Text="{Binding PendingToolName}" FontSize="15"
                                                   FontAttributes="Bold" TextColor="#58a6ff" />
                                            <Label Text="{Binding FormattedToolInput}" FontSize="12"
                                                   FontFamily="monospace" TextColor="#aaa"
                                                   MaxLines="10" LineBreakMode="TailTruncation" />
                                            <HorizontalStackLayout Spacing="8">
                                                <Button Text="Allow"
                                                        Command="{Binding ApproveCommand}"
                                                        CommandParameter="allow"
                                                        BackgroundColor="#238636" TextColor="White"
                                                        FontSize="13" Padding="16,8" FontAttributes="Bold" />
                                                <Button Text="Deny"
                                                        Command="{Binding ApproveCommand}"
                                                        CommandParameter="deny"
                                                        BackgroundColor="#da3633" TextColor="White"
                                                        FontSize="13" Padding="16,8" FontAttributes="Bold" />
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    </Border>

                                    <!-- Actions -->
                                    <HorizontalStackLayout Spacing="8">
                                        <Button Text="Connect"
                                                Command="{Binding ConnectCommand}"
                                                FontSize="12" Padding="12,6" />
                                        <Button Text="Kill"
                                                Command="{Binding DeleteCommand}"
                                                BackgroundColor="#880000" TextColor="White"
                                                FontSize="12" Padding="12,6" />
                                    </HorizontalStackLayout>

                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Available projects -->
                <Label Text="Projects" FontSize="18" FontAttributes="Bold" Margin="0,8,0,0" />
                <CollectionView ItemsSource="{Binding AllProjects}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProjectItem">
                            <Border Stroke="#555" StrokeThickness="1" Padding="12"
                                    StrokeShape="RoundRectangle 6" Margin="0,0,0,4">
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                    <Label Text="{Binding ProjectDir}" FontSize="14" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding ServerLabel}" FontSize="11"
                                           TextColor="Gray" FontFamily="monospace" VerticalOptions="Center" />
                                    <Button Grid.Column="2" Text="Launch"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SessionListViewModel}}, Path=CreateSessionFromProjectCommand}"
                                            CommandParameter="{Binding .}"
                                            FontSize="12" Padding="10,4" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
